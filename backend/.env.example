# EduLens Backend Configuration

# Debug mode
DEBUG=true

# Frontend URL (CORS)
FRONTEND_URL=http://localhost:3000

# ========================================
# CurricuLLM API — Core LLM Provider
# ========================================
# Get your key at https://console.curricullm.com/keys
CURRICULLM_API_KEY=your-curricullm-jwt-token-here
CURRICULLM_BASE_URL=https://api.curricullm.com
CURRICULLM_MODEL=CurricuLLM-AU

# ========================================
# Weaviate Vector Database
# ========================================
WEAVIATE_URL=http://localhost:8080
WEAVIATE_API_KEY=

# ========================================
# ERIC API (1.5M+ educational resources)
# ========================================
# ERIC is free, no API key required
ERIC_BASE_URL=https://api.ies.ed.gov/eric/

# ========================================
# Pipeline Settings
# ========================================
# Dual-agent consensus threshold (0-10). Below this triggers auto-retry.
CONSENSUS_THRESHOLD=7.0
# Max retry attempts for search pipeline
MAX_PIPELINE_RETRIES=1
# Max sources to retrieve per search
MAX_SOURCES=10
# Max sources after reranking
RERANK_TOP_K=6
